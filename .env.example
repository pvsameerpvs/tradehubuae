# === DATABASE ===
DATABASE_URL="postgresql://tradehub:tradehub123@localhost:5432/tradehubuae?schema=public"

# === REDIS ===
REDIS_URL="redis://localhost:6379"

# === GOOGLE OAUTH ===
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# === JWT ===
JWT_SECRET="your-jwt-secret-min-32-chars-long"
JWT_EXPIRES_IN="7d"

# === AI (Google Gemini) ===
GEMINI_API_KEY="your-gemini-api-key"

# === STORAGE (AWS S3 / Cloudflare R2) ===
STORAGE_PROVIDER="r2"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="auto"
R2_ACCOUNT_ID="your-r2-account-id"
R2_BUCKET="tradehubuae-media"
R2_PUBLIC_URL="https://pub-xxxxx.r2.dev"
STORAGE_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"

# === EMAIL (Resend) ===
RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM="TradeHub UAE <orders@tradehubuae.com>"

# === NEXT.JS ===
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="ws://localhost:4000"
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"

# === API ===
API_PORT=4000
API_HOST="0.0.0.0"
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# === PAYMENT ===
COD_ENABLED="true"
# CARD_ENABLED="false"
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# TABBY_API_KEY=""
# TAMARA_API_KEY=""

# === CURRENCY ===
DEFAULT_CURRENCY="AED"
DEFAULT_LOCALE="en-AE"

# === SEO ===
SITE_NAME="TradeHub UAE"
SITE_DESCRIPTION="UAE's Premier Destination for IT Equipment - New & Refurbished Laptops, PCs, Components"
SITE_URL="https://tradehubuae.com"

# === BULL (Queue) ===
BULL_PREFIX="tradehub"
BULL_DEFAULT_JOBS=5

# === FEATURE FLAGS ===
FEATURE_AI_PRODUCT_GENERATION="true"
FEATURE_BULK_SALES="true"
FEATURE_COMBO_OFFERS="true"
FEATURE_COMPARE_PRODUCTS="true"
FEATURE_WISHLIST="true"
